#!/usr/bin/env bash
set -euo pipefail

# =============================================================================
# Shade CLI — cross-platform service deployment with bun build
#
# Usage: shade <command> [service...]
#
# Commands:
#   deploy    Build + install + start services (default: all)
#   build     Compile standalone binaries only
#   install   Generate and install service definitions
#   start     Start services
#   stop      Stop services
#   restart   Restart services
#   status    Show service status
#   logs      Tail service logs
#   uninstall Stop and remove service definitions
#
# Adding a new service: add an entry to the registry functions below.
# =============================================================================

PROJECT_DIR="$(cd "$(dirname "$0")" && pwd)"
BUN_PATH="$(command -v bun)"

# --- Service Registry ---
# To add a service: add its name to ALL_SERVICES and entries to the two lookup functions.
ALL_SERVICES="backend worker"

service_entry() {
  case "$1" in
    backend) echo "backend/src/index.ts" ;;
    worker)  echo "packages/shade-worker/src/index.ts" ;;
    *)       echo "" ;;
  esac
}

service_after() {
  case "$1" in
    worker) echo "shade-backend" ;;
    *)      echo "" ;;
  esac
}

# Packages that fail to bundle (CJS interop issues) and must resolve from node_modules at runtime
service_externals() {
  case "$1" in
    backend) echo "passport-local-mongoose @anthropic-ai/claude-agent-sdk ws" ;;
    *)       echo "" ;;
  esac
}

# Directory containing node_modules for external resolution (workspace that owns the deps)
service_node_modules() {
  case "$1" in
    backend) echo "backend/node_modules" ;;
    *)       echo "" ;;
  esac
}

# --- Platform Detection ---
detect_platform() {
  case "$(uname -s)" in
    Darwin) echo "macos" ;;
    Linux)  echo "linux" ;;
    *)      echo "Unsupported platform: $(uname -s)" >&2; exit 1 ;;
  esac
}

PLATFORM="$(detect_platform)"

# --- Directory Defaults ---
if [[ "$PLATFORM" == "macos" ]]; then
  DEFAULT_DATA_DIR="$HOME/Library/Application Support/Shade/data"
  LOG_DIR="$HOME/Library/Logs/Shade"
  LAUNCHAGENT_DIR="$HOME/Library/LaunchAgents"
else
  DEFAULT_DATA_DIR="$HOME/.local/share/shade/data"
  LOG_DIR=""  # systemd uses journal
  SYSTEMD_DIR="$HOME/.config/systemd/user"
fi

CONFIG_DIR="$HOME/.config/shade"

# --- Helpers ---
resolve_services() {
  if [[ $# -gt 0 ]]; then
    echo "$@"
  else
    echo "$ALL_SERVICES"
  fi
}

ensure_config() {
  local name="$1"
  local env_file="$CONFIG_DIR/shade-${name}.env"
  local template="$PROJECT_DIR/config/shade-${name}.env.example"

  mkdir -p "$CONFIG_DIR"

  if [[ -f "$env_file" ]]; then
    echo "  Config exists: $env_file"
  elif [[ -f "$template" ]]; then
    cp "$template" "$env_file"
    echo "  Created config from template: $env_file"
  else
    touch "$env_file"
    echo "  Created empty config: $env_file"
  fi

  # Auto-generate secrets if empty
  if grep -q '^TOKEN_SECRET=$' "$env_file" 2>/dev/null; then
    local secret
    secret="$(openssl rand -hex 32)"
    sed -i.bak "s/^TOKEN_SECRET=$/TOKEN_SECRET=${secret}/" "$env_file" && rm -f "${env_file}.bak"
    echo "  Generated TOKEN_SECRET"
  fi
  if grep -q '^REFRESH_TOKEN_SECRET=$' "$env_file" 2>/dev/null; then
    local secret
    secret="$(openssl rand -hex 32)"
    sed -i.bak "s/^REFRESH_TOKEN_SECRET=$/REFRESH_TOKEN_SECRET=${secret}/" "$env_file" && rm -f "${env_file}.bak"
    echo "  Generated REFRESH_TOKEN_SECRET"
  fi

  # Set SHADE_DATA_DIR if empty
  if grep -q '^SHADE_DATA_DIR=$' "$env_file" 2>/dev/null; then
    sed -i.bak "s|^SHADE_DATA_DIR=$|SHADE_DATA_DIR=${DEFAULT_DATA_DIR}|" "$env_file" && rm -f "${env_file}.bak"
    echo "  Set SHADE_DATA_DIR=$DEFAULT_DATA_DIR"
  fi
}

ensure_data_dirs() {
  local env_file="$CONFIG_DIR/shade-backend.env"
  local data_dir="$DEFAULT_DATA_DIR"

  if [[ -f "$env_file" ]]; then
    local val
    val="$(grep '^SHADE_DATA_DIR=' "$env_file" | cut -d= -f2- || true)"
    if [[ -n "$val" ]]; then
      data_dir="$val"
    fi
  fi

  mkdir -p "$data_dir" "$data_dir/groups" "$data_dir/sessions" "$data_dir/ipc" "$data_dir/plugins"
  echo "  Data directories: $data_dir"
}

# --- Build ---
cmd_build() {
  local names
  names="$(resolve_services "$@")"

  mkdir -p "$PROJECT_DIR/dist"

  for name in $names; do
    local entry
    entry="$(service_entry "$name")"
    if [[ -z "$entry" ]]; then
      echo "Unknown service: $name" >&2
      exit 1
    fi

    # Build external flags from service_externals
    local ext_flags=""
    local externals
    externals="$(service_externals "$name")"
    for ext in $externals; do
      ext_flags="$ext_flags --external $ext"
    done

    echo "Building shade-${name}..."
    # shellcheck disable=SC2086
    (cd "$PROJECT_DIR" && bun build "$entry" --outfile "dist/shade-${name}.js" --target bun $ext_flags)

    # Symlink node_modules into dist/ for external package resolution
    local nm
    nm="$(service_node_modules "$name")"
    if [[ -n "$nm" && -d "$PROJECT_DIR/$nm" && ! -e "$PROJECT_DIR/dist/node_modules" ]]; then
      ln -sf "../$nm" "$PROJECT_DIR/dist/node_modules"
    fi

    echo "  Built: dist/shade-${name}.js"
  done
}

# --- Install (generate service definitions) ---
install_launchd() {
  local name="$1"
  local env_file="$CONFIG_DIR/shade-${name}.env"
  local plist_path="$LAUNCHAGENT_DIR/com.shade.${name}.plist"

  mkdir -p "$LAUNCHAGENT_DIR" "$LOG_DIR"

  # Build environment variables XML from .env file
  local env_xml=""
  if [[ -f "$env_file" ]]; then
    while IFS='=' read -r key value; do
      # Skip comments and empty lines
      [[ -z "$key" || "$key" == \#* ]] && continue
      # Strip quotes
      value="${value%\"}" ; value="${value#\"}"
      value="${value%\'}" ; value="${value#\'}"
      env_xml="${env_xml}      <key>${key}</key>
      <string>${value}</string>
"
    done < "$env_file"
  fi

  # Add PATH so spawned processes (claude, etc.) can be found
  env_xml="${env_xml}      <key>PATH</key>
      <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:${HOME}/.local/bin:${HOME}/.bun/bin</string>"

  cat > "$plist_path" <<EOF
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.shade.${name}</string>

  <key>ProgramArguments</key>
  <array>
    <string>${BUN_PATH}</string>
    <string>run</string>
    <string>${PROJECT_DIR}/dist/shade-${name}.js</string>
  </array>

  <key>WorkingDirectory</key>
  <string>${PROJECT_DIR}</string>

  <key>EnvironmentVariables</key>
  <dict>
${env_xml}
  </dict>

  <key>RunAtLoad</key>
  <true/>

  <key>KeepAlive</key>
  <dict>
    <key>SuccessfulExit</key>
    <false/>
  </dict>

  <key>StandardOutPath</key>
  <string>${LOG_DIR}/shade-${name}.out.log</string>

  <key>StandardErrorPath</key>
  <string>${LOG_DIR}/shade-${name}.err.log</string>

  <key>SoftResourceLimits</key>
  <dict>
    <key>NumberOfFiles</key>
    <integer>65536</integer>
  </dict>
</dict>
</plist>
EOF

  echo "  Installed: $plist_path"
}

install_systemd() {
  local name="$1"
  local env_file="$CONFIG_DIR/shade-${name}.env"
  local unit_path="$SYSTEMD_DIR/shade-${name}.service"
  local after
  after="$(service_after "$name")"

  mkdir -p "$SYSTEMD_DIR"

  local after_clause=""
  if [[ -n "$after" ]]; then
    after_clause="After=${after}.service"
  fi

  cat > "$unit_path" <<EOF
[Unit]
Description=Shade ${name}
${after_clause}

[Service]
Type=simple
ExecStart=/usr/bin/env bun run ${PROJECT_DIR}/dist/shade-${name}.js
EnvironmentFile=${env_file}
WorkingDirectory=${PROJECT_DIR}
Restart=on-failure
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=default.target
EOF

  echo "  Installed: $unit_path"
}

cmd_install() {
  local names
  names="$(resolve_services "$@")"

  for name in $names; do
    echo "Installing shade-${name}..."
    ensure_config "$name"

    if [[ "$PLATFORM" == "macos" ]]; then
      install_launchd "$name"
    else
      install_systemd "$name"
    fi
  done

  if [[ "$PLATFORM" == "linux" ]]; then
    systemctl --user daemon-reload
  fi

  ensure_data_dirs
}

# --- Start/Stop/Restart ---
cmd_start() {
  local names
  names="$(resolve_services "$@")"

  for name in $names; do
    echo "Starting shade-${name}..."
    if [[ "$PLATFORM" == "macos" ]]; then
      local plist_path="$LAUNCHAGENT_DIR/com.shade.${name}.plist"
      launchctl unload "$plist_path" 2>/dev/null || true
      launchctl load "$plist_path"
    else
      systemctl --user enable "shade-${name}"
      systemctl --user start "shade-${name}"
    fi
    echo "  Started"
  done
}

cmd_stop() {
  local names
  names="$(resolve_services "$@")"

  for name in $names; do
    echo "Stopping shade-${name}..."
    if [[ "$PLATFORM" == "macos" ]]; then
      launchctl unload "$LAUNCHAGENT_DIR/com.shade.${name}.plist" 2>/dev/null || true
    else
      systemctl --user stop "shade-${name}" 2>/dev/null || true
    fi
    echo "  Stopped"
  done
}

cmd_restart() {
  cmd_stop "$@"
  cmd_install "$@"
  cmd_start "$@"
}

# --- Status ---
cmd_status() {
  local names
  names="$(resolve_services "$@")"

  for name in $names; do
    echo "shade-${name}:"
    if [[ "$PLATFORM" == "macos" ]]; then
      local pid
      pid="$(launchctl list | grep "com.shade.${name}" | awk '{print $1}')"
      if [[ -n "$pid" ]]; then
        if [[ "$pid" == "-" ]]; then
          echo "  loaded (not running)"
        else
          echo "  running (pid $pid)"
        fi
      else
        echo "  not loaded"
      fi
    else
      systemctl --user status "shade-${name}" --no-pager 2>/dev/null || echo "  not found"
    fi
    echo ""
  done
}

# --- Logs ---
cmd_logs() {
  local names
  names="$(resolve_services "$@")"

  if [[ "$PLATFORM" == "macos" ]]; then
    local log_files=""
    for name in $names; do
      log_files="$log_files $LOG_DIR/shade-${name}.out.log $LOG_DIR/shade-${name}.err.log"
    done
    # shellcheck disable=SC2086
    tail -f $log_files
  else
    local unit_args=""
    for name in $names; do
      unit_args="$unit_args -u shade-${name}"
    done
    # shellcheck disable=SC2086
    journalctl --user $unit_args -f
  fi
}

# --- Uninstall ---
cmd_uninstall() {
  local names
  names="$(resolve_services "$@")"

  for name in $names; do
    echo "Uninstalling shade-${name}..."
    cmd_stop "$name"

    if [[ "$PLATFORM" == "macos" ]]; then
      rm -f "$LAUNCHAGENT_DIR/com.shade.${name}.plist"
    else
      systemctl --user disable "shade-${name}" 2>/dev/null || true
      rm -f "$SYSTEMD_DIR/shade-${name}.service"
    fi
    echo "  Removed"
  done

  if [[ "$PLATFORM" == "linux" ]]; then
    systemctl --user daemon-reload
  fi
}

# --- Deploy (build + install + start) ---
cmd_deploy() {
  echo "=== Shade Deploy (${PLATFORM}) ==="
  echo "Project: $PROJECT_DIR"
  echo ""

  cmd_build "$@"
  echo ""
  cmd_install "$@"
  echo ""
  cmd_start "$@"

  echo ""
  echo "=== Deploy complete ==="
  echo ""
  echo "Commands:"
  echo "  shade status            Show service status"
  echo "  shade logs [service]    Tail logs"
  echo "  shade restart [service] Restart services"
  echo "  shade stop [service]    Stop services"
  echo ""
  echo "Config: $CONFIG_DIR/"
  echo "Binaries: $PROJECT_DIR/dist/"
  if [[ "$PLATFORM" == "macos" ]]; then
    echo "Logs: $LOG_DIR/"
  else
    echo "Logs: journalctl --user -u shade-backend -f"
  fi
}

# --- Remote Deploy (Tailscale SSH or plain SSH) ---
cmd_remote_deploy() {
  local host="${1:-}"
  shift || true
  local names
  names="$(resolve_services "$@")"

  if [[ -z "$host" ]]; then
    echo "Usage: shade remote-deploy <host> [service...]" >&2
    exit 1
  fi

  echo "=== Remote Deploy to $host ==="

  # Build locally for Linux target
  mkdir -p "$PROJECT_DIR/dist"
  for name in $names; do
    local entry
    entry="$(service_entry "$name")"
    if [[ -z "$entry" ]]; then
      echo "Unknown service: $name" >&2
      exit 1
    fi

    local ext_flags=""
    local externals
    externals="$(service_externals "$name")"
    for ext in $externals; do
      ext_flags="$ext_flags --external $ext"
    done

    echo "Building shade-${name} for Linux..."
    # shellcheck disable=SC2086
    (cd "$PROJECT_DIR" && bun build "$entry" --compile --target=bun-linux-x64 --outfile "dist/shade-${name}-linux" $ext_flags)
    echo "  Built: dist/shade-${name}-linux"

    echo "Uploading to $host..."
    rsync -avz --progress "$PROJECT_DIR/dist/shade-${name}-linux" "$host:/opt/shade/shade-${name}"

    echo "Restarting shade-${name} on $host..."
    ssh "$host" "sudo systemctl restart shade-${name}" || echo "  Warning: restart failed (service may not be installed yet)"
  done

  echo ""
  echo "=== Remote deploy complete ==="
  echo "Check: ssh $host 'sudo systemctl status shade-backend'"
  echo "Logs:  ssh $host 'sudo journalctl -u shade-backend -f'"
}

cmd_remote_setup() {
  local host="${1:-}"
  if [[ -z "$host" ]]; then
    echo "Usage: shade remote-setup <host>" >&2
    exit 1
  fi

  echo "=== Setting up $host ==="
  echo "Uploading setup script and service files..."
  rsync -avz "$PROJECT_DIR/deploy/" "$host:/tmp/shade-deploy/"
  echo "Running setup..."
  ssh "$host" "sudo bash /tmp/shade-deploy/setup-server.sh"
  echo ""
  echo "Server provisioned. Next: shade remote-deploy $host"
}

# --- Movie Search ---
SHADE_API="${SHADE_API_URL:-http://localhost:4020}"

cmd_search() {
  local query="$*"
  if [[ -z "$query" ]]; then
    echo "Usage: shade search <query> [--type objects|characters|text|tags]"
    echo ""
    echo "Examples:"
    echo "  shade search restaurant"
    echo "  shade search \"Billy Crystal\" --type characters"
    echo "  shade search gun --type objects"
    echo "  shade search \"FIVE YEARS\" --type text"
    exit 1
  fi

  # Parse --type flag
  local search_type="all"
  local search_terms=()
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --type) search_type="$2"; shift 2 ;;
      *)      search_terms+=("$1"); shift ;;
    esac
  done
  query="${search_terms[*]}"

  local encoded_query
  encoded_query=$(python3 -c "import urllib.parse; print(urllib.parse.quote('$query'))")

  curl -s --max-time 10 "${SHADE_API}/search?q=${encoded_query}&type=${search_type}" | python3 -c "
import sys, json

data = json.load(sys.stdin)
results = data.get('results', [])
count = data.get('count', 0)

if count == 0:
    print('No results found.')
    sys.exit(0)

print(f'Found {count} matching frames:\n')

for i, r in enumerate(results):
    ts = r.get('timestamp', 0)
    hrs = int(ts // 3600)
    mins = int((ts % 3600) // 60)
    secs = int(ts % 60)
    time_str = f'{hrs:02d}:{mins:02d}:{secs:02d}'

    scene = r.get('sceneDescription', '')[:120]
    mood = r.get('mood', '')
    tags = ', '.join(r.get('tags', []))
    objects = ', '.join([o['label'] for o in r.get('objects', [])])
    chars = ', '.join([c['name'] for c in r.get('characters', [])])
    texts = ' | '.join([t['content'] for t in r.get('text', [])])

    frame = r.get('frame', {})
    img_path = frame.get('imagePath', '') if isinstance(frame, dict) else ''

    print(f'[{time_str}] {scene}')
    if chars:   print(f'  Characters: {chars}')
    if objects:  print(f'  Objects: {objects}')
    if texts:    print(f'  Text: {texts}')
    if tags:     print(f'  Tags: {tags}')
    if mood:     print(f'  Mood: {mood}')
    if img_path: print(f'  Image: https://api.shade.nang.io/static/movies/{img_path.split(\"/movies/\", 1)[-1] if \"/movies/\" in img_path else img_path}')
    print()
" 2>&1
}

# --- Main ---
COMMAND="${1:-deploy}"
shift || true

case "$COMMAND" in
  deploy)        cmd_deploy "$@" ;;
  build)         cmd_build "$@" ;;
  install)       cmd_install "$@" ;;
  start)         cmd_start "$@" ;;
  stop)          cmd_stop "$@" ;;
  restart)       cmd_restart "$@" ;;
  status)        cmd_status "$@" ;;
  logs)          cmd_logs "$@" ;;
  uninstall)     cmd_uninstall "$@" ;;
  remote-deploy) cmd_remote_deploy "$@" ;;
  remote-setup)  cmd_remote_setup "$@" ;;
  search)        cmd_search "$@" ;;
  *)
    echo "Usage: shade <command> [service...]"
    echo ""
    echo "Local:  deploy, build, install, start, stop, restart, status, logs, uninstall"
    echo "Movie:  search <query> [--type objects|characters|text|tags]"
    echo "Remote: remote-setup <host>, remote-deploy <host> [service...]"
    echo ""
    echo "Services: $ALL_SERVICES"
    exit 1
    ;;
esac
