# Shade environment variables
#
# Copy this file to `.env` and fill in real values, then restart `bun run dev`
# for the affected workspace.
#
# Service credentials (API keys, webhooks, tokens) belong in the AppConfig
# MongoDB document — the backend hydrates `process.env` from
# `AppConfig.apiKeys.*` at boot for any key that isn't already set in the
# environment. So the credentials below are OPTIONAL here; they work but the
# canonical home is AppConfig (edit via `/admin/app-configs`). Bootstrap-level
# values (MongoDB URI, port, JWT secrets) stay here since they're needed
# before the DB is reachable.

# ------------------------------------------------------------------------------
# Backend (cd backend && bun run dev)
# ------------------------------------------------------------------------------

# MongoDB connection string. Override to point at a remote cluster.
MONGO_URI=mongodb://localhost:27017/shade

# MongoDB connection string for the trivia-specific database.
TRIVIA_MONGO_URI=mongodb://localhost:27017/trivia

# HTTP port the backend listens on. Default: 4020.
PORT=4020

# Signing secrets for JWT access + refresh tokens. Generate with `openssl rand -hex 32`.
TOKEN_SECRET=
REFRESH_TOKEN_SECRET=

# node env: "production" turns on deployed-mode logging/error handling.
NODE_ENV=development

# Pino log level: debug | info | warn | error
LOG_LEVEL=debug

# Where to write uploaded/cached data (movies, recordings, frames).
# Defaults to `./data` in the backend cwd.
SHADE_DATA_DIR=

# Public base URL the backend advertises to integrations (Slack Block Kit buttons,
# webhook callbacks, etc). Defaults to https://shade-api.nang.io.
SHADE_PUBLIC_URL=

# Anthropic + OpenRouter credentials used by the orchestrator and trivia services.
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=

# Model overrides for the trivia pipeline (optional).
ANSWERER_MODEL=claude-sonnet-4-20250514
DETECTOR_MODEL=claude-haiku-4-5-20251001

# Deepgram credentials for the radio transcriber.
DEEPGRAM_API_KEY=

# ACRCloud music recognition (optional).
ACRCLOUD_ACCESS_KEY=
ACRCLOUD_SECRET_KEY=

# GitHub token used by the PR watcher service.
GITHUB_TOKEN=

# Brave Search API key (also configurable via AppConfig).
BRAVE_SEARCH_API_KEY=

# MCP media server auth + upstream services.
MCP_AUTH_TOKEN=
MCP_PORT=
SONARR_URL=
SONARR_API_KEY=
RADARR_URL=
RADARR_API_KEY=
NZBGET_URL=
PLEX_URL=
PLEX_TOKEN=

# Sentry DSN for server-side error tracking (optional).
SENTRY_DSN=

# ------------------------------------------------------------------------------
# Frontend (cd frontend && bun run web)
# ------------------------------------------------------------------------------

# Public API URL the web/native client hits. Must start with http:// or https://.
EXPO_PUBLIC_API_URL=http://localhost:4020

# Only set when building for E2E: skips font loading so Playwright doesn't time
# out on fonts served from a static bundle.
EXPO_PUBLIC_SKIP_FONT_WAIT=

# Override the OpenAPI schema URL used by `bun run sdk` to regenerate the SDK.
OPENAPI_URL=http://localhost:4020/openapi.json
