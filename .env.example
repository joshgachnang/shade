# Shade environment variables
#
# Copy this file to `.env` and fill in real values, then restart `bun run dev`
# for the affected workspace.
#
# Almost everything below is OPTIONAL here — the canonical home for app config
# is the `AppConfig` document in MongoDB (edit via `/admin/app-configs`). At
# boot the backend copies any `AppConfig.*` value into the matching env var if
# the env var isn't already set, so env always wins over config.
#
# The few values that MUST stay in this file are bootstrap-only — they're
# needed before the database (and therefore AppConfig) is reachable:
#   - MONGO_URI, TRIVIA_MONGO_URI
#   - PORT
#   - NODE_ENV
#   - SENTRY_DSN
#
# Everything else has a reasonable default in AppConfig (including randomly
# generated JWT and MCP auth secrets on first boot), so you can run Shade
# without providing any of the values in the "App-level config" sections.

# ==============================================================================
# Bootstrap — required to start the process
# ==============================================================================

# MongoDB connection string. Required.
MONGO_URI=mongodb://localhost:27017/shade

# MongoDB connection string for the trivia-specific database.
TRIVIA_MONGO_URI=mongodb://localhost:27017/trivia

# HTTP port the backend listens on. Default: 4020.
PORT=4020

# "production" turns on deployed-mode logging/error handling.
NODE_ENV=development

# Sentry DSN for server-side error tracking (optional; no AppConfig fallback).
SENTRY_DSN=

# ==============================================================================
# App-level config — optional here, lives in AppConfig.*
# ==============================================================================
# Each variable below has a matching AppConfig field. The env var, if set,
# overrides AppConfig. Edit values via the admin UI at /admin/app-configs.
# Changing these at runtime requires a Shade restart to take effect; the
# backend will log a warning that lists which fields changed.

# --- Filesystem & URLs (AppConfig.dataDir, AppConfig.publicUrl) ---
# Where Shade writes uploaded/cached data (movies, recordings, frames, etc.).
# AppConfig field: `dataDir`. Default: ./data
SHADE_DATA_DIR=

# Public base URL the backend advertises to integrations (Slack Block Kit
# buttons, webhook callbacks, etc.).
# AppConfig field: `publicUrl`. Default: https://shade-api.nang.io
SHADE_PUBLIC_URL=

# --- Logging (AppConfig.logging.level) ---
# pino/winston log level: debug | info | warn | error
# AppConfig field: `logging.level`. Default: "debug" in dev, "info" in prod.
LOG_LEVEL=

# --- Auth (AppConfig.auth.*) ---
# Signing secrets for JWT access + refresh tokens. On first boot Shade
# generates random defaults; you only need to set these if you want to
# control rotation or share a key across multiple instances.
# Generate with: `openssl rand -hex 32`
TOKEN_SECRET=
REFRESH_TOKEN_SECRET=

# --- Model overrides for trivia pipeline (AppConfig.models.*) ---
ANSWERER_MODEL=
DETECTOR_MODEL=

# --- Third-party API keys (AppConfig.apiKeys.*) ---
# Anthropic + OpenRouter credentials used by the orchestrator and trivia services.
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=

# Deepgram credentials for the radio transcriber.
DEEPGRAM_API_KEY=

# ACRCloud music recognition (optional).
ACRCLOUD_ACCESS_KEY=
ACRCLOUD_SECRET_KEY=

# GitHub token used by the PR watcher service.
GITHUB_TOKEN=

# Web search providers.
BRAVE_SEARCH_API_KEY=
EXA_API_KEY=
TAVILY_API_KEY=

# --- MCP media server creds (AppConfig.mcpMedia.*) ---
# Auth token for the standalone media MCP server. Generated randomly on first
# boot; override here if you want a specific value.
MCP_AUTH_TOKEN=

# MCP server port. Default: 8081.
MCP_PORT=

# Sonarr, Radarr, NZBGet, Plex. All optional; unconfigured services' tools
# return a helpful error instead of crashing.
SONARR_URL=
SONARR_API_KEY=
RADARR_URL=
RADARR_API_KEY=
NZBGET_URL=
NZBGET_USERNAME=
NZBGET_PASSWORD=
PLEX_URL=
PLEX_TOKEN=

# ==============================================================================
# Frontend (cd frontend && bun run web)
# ==============================================================================

# Public API URL the web/native client hits. Must start with http:// or https://.
EXPO_PUBLIC_API_URL=http://localhost:4020

# Only set when building for E2E: skips font loading so Playwright doesn't time
# out on fonts served from a static bundle.
EXPO_PUBLIC_SKIP_FONT_WAIT=

# Override the OpenAPI schema URL used by `bun run sdk` to regenerate the SDK.
OPENAPI_URL=http://localhost:4020/openapi.json
