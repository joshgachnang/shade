# Required: Bearer token for MCP auth
MCP_AUTH_TOKEN=your-secret-token-here

# Optional: Port (default 8081)
MCP_PORT=8081

# Sonarr (optional — omit to skip Sonarr tools)
SONARR_URL=http://localhost:8989
SONARR_API_KEY=your-sonarr-api-key

# Radarr (optional — omit to skip Radarr tools)
RADARR_URL=http://localhost:7878
RADARR_API_KEY=your-radarr-api-key

# NZBGet (optional — omit to skip NZBGet tools)
NZBGET_URL=http://localhost:6789
NZBGET_USERNAME=nzbget
NZBGET_PASSWORD=your-nzbget-password

# Plex (optional — omit to skip Plex tools)
PLEX_URL=http://localhost:32400
PLEX_TOKEN=your-plex-token
