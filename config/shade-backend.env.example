# Shade Backend Configuration
# Copy to ~/.config/shade/shade-backend.env and edit values

# Server
PORT=4020
NODE_ENV=production

# MongoDB
MONGO_URI=mongodb://localhost:27017/shade

# Auth secrets (auto-generated by deploy.sh if left empty)
TOKEN_SECRET=
REFRESH_TOKEN_SECRET=

# Anthropic
ANTHROPIC_API_KEY=

# Data directory (absolute path required for compiled binaries)
# macOS default: ~/Library/Application Support/Shade/data
# Linux default: ~/.local/share/shade/data
SHADE_DATA_DIR=

# Assistant
SHADE_ASSISTANT_NAME=Shade
